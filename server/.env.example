PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jobminer
JWT_SECRET=your-long-random-secret-here
GEMINI_API_KEY=your-gemini-key-here
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
REMOTIVE_API_KEY=your-remotive-api-key
JSEARCH_API_KEY=your-jsearch-api-key

# Security & DDoS Prevention
# - Rate limiting: 100 requests per 15 minutes (general), 30 per minute (search)
# - HTTPS headers enabled (HSTS, CSP, X-Frame-Options)
# - Helmet.js protects against common vulnerabilities
# - Request size limits: 10MB
# - Insurance: Covered by best practices - DDoS protection via rate limiting